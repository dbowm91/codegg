{
  "$schema": "https://opencode.ai/schema/config.json",
  "log_level": "info",
  
  "model": "opencode_zen/minimax-m2.5-free",
  "small_model": "opencode_zen/nemotron-3-super-free",
  
  "username": "your-username",
  "share": "public",
  
  "autoupdate": {
    "enabled": true,
    "check_interval_hours": 24
  },
  
  "server": {
    "port": 3000,
    "hostname": "0.0.0.0",
    "mdns": true,
    "mdns_domain": "opencode.local",
    "cors_origins": ["https://opencode.ai"],
    "tool_timeout_seconds": 120,
    "max_parallel_tools": 5
  },
  
  "model_profile": {
    "openai/gpt-5": {
      "task_state_policy": {
        "mode": "explicit_todo",
        "update_frequency": "milestones_and_task_switches",
        "max_total_items": 10,
        "expose_completed_items": "summary_only",
        "allow_model_todo_read": true,
        "allow_model_todo_write": true,
        "require_single_in_progress": true,
        "require_blocker_reason": false,
        "inject_after_tool_calls": 5,
        "inject_on_resume": true,
        "inject_after_compaction": true,
        "subagent_todo_access": "none"
      }
    }
  },
  
  "provider": {
    "anthropic": {
      "auth": { "type": "api_key", "env": "ANTHROPIC_API_KEY" },
      "base_url": "https://api.anthropic.com",
      "timeout": "60s",
      "whitelist": ["claude-sonnet-4-20250514", "claude-opus-4-20250514"]
    },
    "openai": {
      "auth": { "type": "api_key", "env": "OPENAI_API_KEY" },
      "base_url": "https://api.openai.com/v1",
      "timeout": "30s",
      "options": {
        "max_retries": 3
      }
    },
    "google": {
      "auth": { "type": "api_key", "env": "GOOGLE_API_KEY" },
      "timeout": "45s"
    },
    "openrouter": {
      "auth": { "type": "api_key", "env": "OPENROUTER_API_KEY" },
      "base_url": "https://openrouter.ai/api/v1"
    },
    "opencode_zen": {
      "auth": { "type": "api_key", "env": "OPENCODE_ZEN_API_KEY" },
      "base_url": "https://opencode.ai/zen/v1",
      "models": {
        "minimax-m2.5-free": {
          "context_window": 200000,
          "max_output_tokens": 64000,
          "supports_tools": true
        },
        "big-pickle": {
          "context_window": 200000,
          "max_output_tokens": 64000,
          "supports_tools": true
        },
        "nemotron-3-super-free": {
          "context_window": 128000,
          "max_output_tokens": 32000,
          "supports_tools": true
        },
        "qwen3.6-plus-free": {
          "context_window": 128000,
          "max_output_tokens": 32000,
          "supports_tools": true
        }
      }
    },
    "xai": {
      "auth": { "type": "api_key", "env": "XAI_API_KEY" }
    }
  },

  // Provider auth modes
  //
  // Each `provider.<id>.auth` block uses one of:
  //
  //   { "type": "api_key", "env": "VENDOR_API_KEY" }      - read from env (default fallback {VENDOR}_API_KEY)
  //   { "type": "api_key", "value": "sk-..." }           - inline (avoid; prefer env or store)
  //   { "type": "api_key", "encrypted_value": "v2:..." } - encrypted at rest
  //   { "type": "stored", "account_id": "default" }      - resolve from user credential store
  //   { "type": "external_command", "command": "...", "args": ["..."], "timeout_ms": 5000 }
  //                                                      - shells out (recognized; currently unsupported
  //                                                        in the synchronous resolver, see ARCHITECTURE)
  //   { "type": "oauth_device", "client_id": "...", "auth_url": "...", "token_url": "..." }
  //                                                      - typed but not yet implemented
  //   { "type": "none" }                                  - explicit no-auth marker
  //
  // Legacy: the original `api_key` and `encrypted_api_key` fields on the
  // provider object are still honored as a fallback. Stored credentials
  // live in `~/.config/codegg/credentials.json` and require
  // `CODEGG_MASTER_KEY` to be set. Use `codegg auth status`,
  // `codegg auth set-key <provider>`, and `codegg auth logout <provider>`
  // to manage them.
  
  "mcp": {
    "filesystem": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "."],
      "env": {}
    },
    "github": {
      "command": "uvx",
      "args": ["mcp-server-github", "--token", "ghp_..."]
    }
  },
  
  "permission": {
    "allow": [
      { "tool": "bash", "path": "**/node_modules/**" },
      { "tool": "read", "path": "**/*" },
      { "tool": "glob", "path": "**/*" },
      { "tool": "grep", "path": "**/*" }
    ],
    "deny": [
      { "tool": "bash", "path": "**/secrets/**" },
      { "tool": "edit", "path": "**/node_modules/**" }
    ],
    "auto_respond": true,
    "auto_allow_duration_seconds": 300
  },
  
  "compaction": {
    "enabled": true,
    "auto": true,
    "prune": false,
    "max_tokens": 200000,
    "threshold": 0.8,
    "reserved": 10000
  },
  
  "skills": {
    "directories": [".opencode/skills"],
    "default": ["docs", "testing"]
  },
  
  "commands": {
    "git": {
      "command": "git",
      "always_allow": true
    },
    "npm": {
      "command": "npm"
    }
  },
  
  "tools": {
    "bash": true,
    "read": true,
    "edit": true,
    "glob": true,
    "grep": true,
    "apply_patch": true,
    "multiedit": true,
    "webfetch": true,
    "question": true
  },
  
  "formatter": {
    "rules": {
      "rs": {
        "command": ["rustfmt", "$FILE"],
        "disabled": false
      },
      "js": {
        "command": ["prettier", "--write", "$FILE"],
        "disabled": false
      },
      "ts": {
        "command": ["prettier", "--write", "$FILE"],
        "disabled": false
      }
    }
  },
  
  "lsp": {
    "rust": {
      "command": "rust-analyzer"
    },
    "typescript": {
      "command": "typescript-language-server",
      "args": ["--stdio"]
    }
  },
  
  "watcher": {
    "enabled": true,
    "debounce_ms": 500
  },
  
  "plugin": [
    {
      "id": "custom-plugin",
      "path": "./plugins/custom.wasm"
    }
  ],
  
  "experimental": {
    "stream_tool_output": true,
    "compact_on_overflow": true
  },
  
  "keybinds": {
    "ctrl+enter": "submit",
    "ctrl+c": "cancel",
    "ctrl+l": "clear"
  },
  
  "instructions": [
    "Always write tests before committing code",
    "Use meaningful commit messages"
  ]
}
